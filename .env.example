# PostgreSQL (async driver for SQLAlchemy + asyncpg)
# From the host machine use published port 15432 (see docker-compose). Inside Compose, use @db:5432.
DATABASE_URL=postgresql+asyncpg://yonnn_user:yonnn_password@localhost:15432/yonnn_db

# JWT auth (use a long random secret in production, e.g. openssl rand -hex 32)
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional: on startup, create this user as superuser or promote if email exists (password min 8 chars)
# SUPERUSER_EMAIL=admin@example.com
# SUPERUSER_PASSWORD=change-me-min-8-chars

# Redis (Celery broker / cache) Task Queue
REDIS_URL=redis://localhost:6379/0

# MinIO / S3-compatible API (raw tool outputs, logs, screenshots)
# Access keys and bucket names can be added in a later settings module.
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadminpassword

# External API Keys (Get these ready!)
H1_API_KEY=your_key
BUG_CROWD_KEY=your_key
TELEGRAM_BOT_TOKEN=your_token
TELEGRAM_CHAT_ID=your_id